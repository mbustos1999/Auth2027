{
  "name": "auth-2027",
  "version": "1.0.1003",
  "description": "ArgenMod Auth",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbustos1999/Auth2027.git"
  },
  "scripts": {
    "start": "concurrently \"npm run electron\" \"npm run bot\"",
    "electron": "electron .",
    "bot": "npm start --prefix bot",
    "dev": "electron . --enable-logging",
    "build": "node scripts/build-with-obfuscation.js",
    "build:win": "node scripts/build-with-obfuscation.js --win",
    "build:mac": "node scripts/build-with-obfuscation.js --mac",
    "build:no-obfuscate": "node scripts/inject-build-config.js && electron-builder",
    "release": "node scripts/build-with-obfuscation.js --publish always"
  },
  "keywords": [
    "electron",
    "auth",
    "wordpress"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0",
    "javascript-obfuscator": "^4.2.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "unzipper": "^0.12.3"
  },
  "build": {
    "appId": "com.auth2027.app",
    "productName": "Argenmod Auth",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.map",
      "!modManager",
      "!**/.env",
      "!**/.env.*",
      "!**/.env.local",
      "!build-config.js",
      "!.env",
      "!.env.*"
    ],
    "extraResources": [
      {
        "from": "modManager",
        "to": "modManager",
        "filter": [
          "**/*",
          "!Mods/FC26/*.fifamod",
          "!Mods/FC26/*.zip"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "mbustos1999",
      "repo": "Auth2027"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/argenmod.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/argenmod.png",
      "category": "public.app-category.utilities"
    }
  }
}
