{
  "name": "auth-2027",
  "version": "1.0.10",
  "description": "Aplicación Electron con autenticación WordPress",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbustos1999/Auth2027.git"
  },
  "scripts": {
    "start": "concurrently \"npm run electron\" \"npm run bot\"",
    "electron": "electron .",
    "bot": "npm start --prefix bot",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "release": "node -e \"require('dotenv').config(); require('child_process').execSync('npx electron-builder --publish always', {stdio:'inherit', env: process.env})\""
  },
  "keywords": [
    "electron",
    "auth",
    "wordpress"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "unzipper": "^0.12.3"
  },
  "build": {
    "appId": "com.auth2027.app",
    "productName": "Auth2027",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.map",
      "!modManager"
    ],
    "extraResources": [
      {
        "from": "modManager",
        "to": "modManager",
        "filter": [
          "**/*",
          "!Mods/FC26/*.fifamod",
          "!Mods/FC26/*.zip"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "mbustos1999",
      "repo": "Auth2027"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    }
  }
}
