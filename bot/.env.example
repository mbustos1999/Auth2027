# Copia este archivo a .env y rellena con tus valores reales.
# NUNCA commitees .env con secretos reales.

DISCORD_BOT_TOKEN=tu_token_del_bot_de_discord

SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_super_secreta

# OAuth Discord (callback)
DISCORD_CLIENT_ID=tu_client_id
DISCORD_CLIENT_SECRET=tu_client_secret
DISCORD_REDIRECT_URI=https://tu-dominio.up.railway.app/auth/discord/callback

# Seguridad: secreto compartido entre app Electron y bot (obligatorio en producción)
BOT_SHARED_SECRET=genera_un_secreto_largo_y_aleatorio

# MercadoPago (opcional)
MERCADOPAGO_ACCESS_TOKEN_ARG=
MERCADOPAGO_ACCESS_TOKEN_CHILE=

# Opcional: ID del servidor, puerto OAuth
GUILD_ID=
OAUTH_SERVER_PORT=4000
