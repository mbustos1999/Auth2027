# Copia a .env y rellena. NUNCA commitees .env con secretos.

# API WordPress
AUTH_API_URL=https://argenmod.com
AUTH_ENDPOINT=/wp-json/argenmod/v1/validar-login

# Supabase (anon key es pública; service_role NUNCA aquí)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=

# Bot (URL del backend)
AUTH_APP_BOT_URL=https://auth2027-production.up.railway.app

# Seguridad: debe coincidir con BOT_SHARED_SECRET del bot
BOT_SHARED_SECRET=

# Discord OAuth (opcional si el bot expone /config)
DISCORD_OAUTH_BASE_URL=
DISCORD_INVITE_URL=

# MercadoPago (solo si la app consulta MP directamente; normalmente lo hace el bot)
MERCADOPAGO_ACCESS_TOKEN_ARG=
MERCADOPAGO_ACCESS_TOKEN_CHILE=
